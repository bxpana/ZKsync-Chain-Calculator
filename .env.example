# ZKsync Chain Calculator - Configuration
# Copy this file to .env and fill in the values for your chain.

# Display name used in report headers
CHAIN_NAME=My ZKsync Chain

# RPC endpoints
L1_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
L2_RPC=https://your-l2-rpc.example.com

# Data availability mode: "rollup" or "validium"
#   rollup   - pubdata posted to L1 via EIP-4844 blobs (costs scale with TPS)
#   validium - pubdata stored off-chain (L1 costs stay flat regardless of TPS)
DA_MODE=rollup

# L1 operator addresses
COMMIT_OPERATOR=0x0000000000000000000000000000000000000000
PROVE_OPERATOR=0x0000000000000000000000000000000000000000
EXECUTE_OPERATOR=0x0000000000000000000000000000000000000000

# Watchdog address (used on both L1 and L2)
WATCHDOG_ADDRESS=0x0000000000000000000000000000000000000000

# Estimated average pubdata bytes per L2 transaction (used in TPS scaling model).
# Run `python3 measure_pubdata.py` to measure the right value for your chain.
#   Simple transfers: 150-200, Token transfers: 200-400, Complex DeFi: 400-1000
PUBDATA_PER_TX=300
